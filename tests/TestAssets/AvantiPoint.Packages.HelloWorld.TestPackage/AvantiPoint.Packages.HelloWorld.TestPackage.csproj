<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>AvantiPoint.Packages.HelloWorld.TestPackage</PackageId>
    <Version>1.0.0</Version>
    <Description>Hello world package generated by native toolchain integration tests.</Description>
    <Authors>AvantiPoint</Authors>
    <PackageTags>integration-test;hello-world</PackageTags>
  </PropertyGroup>

  <!-- Repo-wide Nerdbank.GitVersioning would pin CI versions; tests pass an explicit /p:Version. -->
  <ItemGroup>
    <PackageReference Remove="Nerdbank.GitVersioning" />
  </ItemGroup>

</Project>
