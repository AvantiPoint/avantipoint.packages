  "ConnectionStrings": {
    "SqlServer": "Server=(localdb)\\mssqllocaldb;Database=OpenFeedDemo;Trusted_Connection=True;MultipleActiveResultSets=true",
    "Sqlite": "Data Source=App_Data\\db\\openfeed.db",
    "MariaDb": "server=127.0.0.1;user=demofeed;password=12345;database=openfeed",
    "MySql": "server=127.0.0.1;user=demofeed;password=12345;database=openfeed"
  }
