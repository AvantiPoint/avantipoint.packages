  // Combine with Search.IncludeMirroredPackages to control search visibility.
  //
  // "PackageSources": [
  //   {
  //     "Name": "NuGet.org",
  //     "FeedUrl": "https://api.nuget.org/v3/index.json",
  //     "Type": "Upstream",
