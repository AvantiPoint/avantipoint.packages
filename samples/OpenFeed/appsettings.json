  //     "IsEnabled": true
  //   },
  //   {
  //     "Name": "dotnet10",
  //     "FeedUrl": "https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet10/nuget/v3/index.json",
  //     "Type": "Upstream",
  //     "CachingStrategy": "CacheOnly",
  //     "IsEnabled": true
  //   },
  //   {
  //     "Name": "Telerik",
  //     "FeedUrl": "https://nuget.telerik.com/nuget",
