{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RunMigrationsAtStartup": true,
  "EnablePackageMetadataBackfill": false,
  "Database": {
    "Type": "Sqlite"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=App_Data/lightweight-feed.db"
  },
  "Storage": {
    "Type": "FileSystem",
    "Path": "App_Data/packages"
  },
  "Search": {
    "Type": "Database",
    "IncludeMirroredPackages": false,
    "EnableUpstreamSearch": true,
    "UpstreamSearchTimeout": "00:00:02",
    "MergeStrategy": "LocalPreferred"
  },
  "LocalCache": {
    "Enabled": true,
    "CopyToFeedStorage": false
  },
  "Mirror": {
    "NuGetConfigPath": "NuGet.Config",
    "DefaultCachingStrategy": "ProxyOnly"
  }
}
