{
  "Host": {
    "ServerName": "AvantiPoint Package Feed",
    "TokenHashPepper": "change-me-in-production",
    "Access": {
      "RequireNewUserApproval": false
    },
    "Authentication": {
      "Providers": []
    }
  },
  "EmailSettings": {
    "Provider": "None",
    "FromAddress": "noreply@localhost",
    "FromName": "Package Feed"
  },
  "Database": {
    "Type": "Sqlite",
    "ConnectionString": "Data Source=App_Data/packages.db"
  },
  "Storage": {
    "Type": "FileStorage",
    "Path": "App_Data/packages"
  },
  "Search": {
    "Type": "Database"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
