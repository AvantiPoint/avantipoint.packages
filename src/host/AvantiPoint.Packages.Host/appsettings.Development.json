{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowPackageOverwrites": true,
  "PackageDeletionBehavior": "Unlist",
  "Host": {
    "ServerName": "AvantiPoint Package Feed (Development)",
    "TokenHashPepper": "development-only-not-for-production",
    "Access": {
      "RequireNewUserApproval": false
    },
    "Authentication": {
      "Microsoft": {
        "ClientId": "",
        "ClientSecret": "",
        "TenantId": "your-tenant-id",
        "AllowedEmailDomains": [],
        "RequiredGroupIds": [],
        "AdminRoleGroupIds": [],
        "PublisherRoleGroupIds": [],
        "ConsumerRoleGroupIds": []
      },
      "Google": {
        "ClientId": "",
        "ClientSecret": "",
        "HostedDomain": "yourcompany.com",
        "RequiredGroupIds": []
      },
      "GitHub": {
        "ClientId": "",
        "ClientSecret": "",
        "Organization": "your-org",
        "TeamSlugs": []
      }
    }
  },
  "EmailSettings": {
    "Provider": "None",
    "FromAddress": "no-reply@localhost",
    "FromName": "AvantiPoint Package Feed (Development)",
    "Postmark": {
      "ServerToken": "REPLACE_ME"
    },
    "SendGrid": {
      "ApiKey": "REPLACE_ME"
    }
  },
  "Database": {
    "Type": "Sqlite",
    "ConnectionString": "Data Source=App_Data/packages-dev.db"
  },
  "Storage": {
    "Type": "FileSystem",
    "Path": "App_Data/packages"
  },
  "Search": {
    "Type": "Database"
  },
  "Shield": {
    "ServerName": "AvantiPoint Package Feed (Development)"
  }
}
