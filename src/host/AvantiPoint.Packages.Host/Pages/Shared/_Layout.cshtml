<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Package Feed</title>
    <link rel="stylesheet" href="~/_content/AvantiPoint.Packages.UI.Razor/css/nuget-theme.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="feed-header">
        <div class="feed-header__brand">
            <strong>Package Feed</strong>
            @(await Html.RenderComponentAsync<AvantiPoint.Packages.UI.Components.MultiFeed.MultiFeedNavigation>(
                Microsoft.AspNetCore.Mvc.Rendering.RenderMode.ServerPrerendered))
        </div>
        <nav>
            @(await Html.RenderComponentAsync<AvantiPoint.Packages.UI.Components.MultiFeed.FeedUiNavigation>(
                Microsoft.AspNetCore.Mvc.Rendering.RenderMode.ServerPrerendered))
            <a href="/Account/ApiKeys">API Keys</a>
            <a href="/Account/Users">Users</a>
            <a href="/Account/PackageSources">Package Sources</a>
            <a href="/Account/PackageGroups">Package Groups</a>
            <a href="/Account/PublishTargets">Publish Targets</a>
            <a href="/Account/AuditLog">Audit Log</a>
            <a href="/Account/Settings">Settings</a>
        </nav>
    </header>
    <main class="feed-main">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
