{
  "Host": {
    "ServerName": "AvantiPoint Package Feed",
    "Access": {
      "RequireNewUserApproval": false
    },
    "Authentication": {}
  },
  // Override via environment variables (double underscore = nested section):
  // EmailSettings__Provider, EmailSettings__FromAddress, EmailSettings__FromName,
  // EmailSettings__Postmark__ServerToken, EmailSettings__SendGrid__ApiKey,
  // EmailSettings__Smtp__Host, EmailSettings__Smtp__Port, EmailSettings__Smtp__Username,
  // EmailSettings__Smtp__Password, EmailSettings__Smtp__EnableSsl,
  // EmailSettings__AmazonSes__Region, EmailSettings__AmazonSes__AccessKey, EmailSettings__AmazonSes__SecretKey,
  // EmailSettings__AzureCommunicationServices__ConnectionString, EmailSettings__AzureCommunicationServices__SenderAddress,
  // EmailSettings__Mailgun__ApiKey, EmailSettings__Mailgun__Domain, EmailSettings__Mailgun__BaseUrl,
  // EmailSettings__Resend__ApiKey
  "EmailSettings": {
    "Provider": "None",
    "FromAddress": "noreply@localhost",
    "FromName": "Package Feed",
    "Postmark": {
      "ServerToken": "REPLACE_ME"
    },
    "SendGrid": {
      "ApiKey": "REPLACE_ME"
    },
    "Smtp": {
      "Host": "",
      "Port": 587,
      "Username": "",
      "Password": "REPLACE_ME",
      "EnableSsl": true
    },
    "AmazonSes": {
      "Region": "us-east-1",
      "AccessKey": "REPLACE_ME",
      "SecretKey": "REPLACE_ME",
      "ConfigurationSetName": ""
    },
    "AzureCommunicationServices": {
      "ConnectionString": "REPLACE_ME",
      "SenderAddress": ""
    },
    "Mailgun": {
      "ApiKey": "REPLACE_ME",
      "Domain": "",
      "BaseUrl": "https://api.mailgun.net"
    },
    "Resend": {
      "ApiKey": "REPLACE_ME"
    }
  },
  "Database": {
    "Type": "Sqlite",
    "ConnectionString": "Data Source=/data/packages.db"
  },
  "Storage": {
    "Type": "FileSystem",
    "Path": "/data/packages"
  },
  "Search": {
    "Type": "Database"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
