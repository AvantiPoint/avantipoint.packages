{
  "Host": {
    "ServerName": "AvantiPoint Package Feed",
    "Access": {
      "RequireNewUserApproval": false
    },
    "Authentication": {}
  },
  "EmailSettings": {
    "Provider": "None",
    "FromAddress": "noreply@localhost",
    "FromName": "Package Feed"
  },
  "Database": {
    "Type": "Sqlite",
    "ConnectionString": "Data Source=/data/packages.db"
  },
  "Storage": {
    "Type": "FileSystem",
    "Path": "/data/packages"
  },
  "Search": {
    "Type": "Database"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
