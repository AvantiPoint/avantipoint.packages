@page "/packages/{PackageId}/{PackageVersion?}"
@model AvantiPoint.Packages.Server.Pages.PackageDetailModel
@using AvantiPoint.Packages.UI.Components
@namespace AvantiPoint.Packages.Server.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
}

@if (Model.IsLoading)
{
    <section class="package-detail-loading" role="status">
        <span>Loading package details…</span>
    </section>
}
else if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <section class="package-detail-error" role="alert">
        <p>@Model.ErrorMessage</p>
    </section>
}
else if (Model.PackageInfo is not null)
{
    @(await Html.RenderComponentAsync<AvantiPoint.Packages.UI.Components.PackageDetail>(
        Microsoft.AspNetCore.Mvc.Rendering.RenderMode.ServerPrerendered,
        new { 
            Package = Model.PackageInfo,
            FeedBaseUrl = Model.FeedBaseUrl,
            FeedDisplayName = "NuGet Feed",
            OnVersionSelected = (Func<string, Task>)Model.HandleVersionSelected
        }))
}

@section Scripts {
    <script src="_framework/blazor.web.js"></script>
}

